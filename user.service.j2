[Unit]
Description = User Service
[Service]
User=roboshop
Environment=MONGO=true
// highlight-start
Environment=REDIS_URL='redis://{{ redis.sairamdaws.online }}:6379'
Environment=MONGO_URL="mongodb://{{ mongodb.sairamdaws.online }}/users"
// highlight-end
ExecStart=/bin/node /app/server.js
SyslogIdentifier=user

[Install]
WantedBy=multi-user.target